{
  "name": "apollo",
  "version": "1.0.0",
  "description": "Azure DevOps + Confluence integration for Claude Code",
  "author": {
    "name": "Alexis Riviere",
    "email": "alexis.riviere@apollossc.com"
  },
  "repository": "https://github.com/apollossc/devtools-plugin",
  "dependencies": [
    { "name": "atlassian", "marketplace": "claude-plugins-official" }
  ],
  "userConfig": {
    "ado_org": {
      "description": "Azure DevOps organization name (ex: apollo-ssc)",
      "sensitive": false
    },
    "ado_project": {
      "description": "Azure DevOps project name (optional — if empty, available projects will be listed for selection)",
      "sensitive": false
    }
  }
}
